{
  "manifest_version": 3,
  "name": "Simple Proxy Switcher",
  "version": "1.2",
  "description": "Quick and clean proxy switcher",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simple Proxy Switcher"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
